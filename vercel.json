{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/spa",
  "installCommand": "npm install",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_MAPBOX_API_KEY": "@mapbox_api_key",
    "VITE_GOOGLE_MAPS_API_KEY": "@google_maps_api_key"
  }
}
